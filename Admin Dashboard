<!DOCTYPE html>
<html>
<head>
<title>Admin Dashboard</title>

<style>
body{font-family:Arial;background:#fff8dc;margin:0;}
header{background:#f4b400;padding:15px;text-align:center;font-size:22px;}
.dashboard{display:flex;gap:20px;padding:20px;}
.card{
  background:#ffeb99;
  padding:20px;
  width:200px;
  text-align:center;
  border-radius:10px;
  font-weight:bold;
}
table{
  width:90%;
  margin:20px auto;
  background:white;
  border-collapse:collapse;
}
th,td{border:1px solid #ccc;padding:10px;text-align:center;}
th{background:#ffcc00;}
</style>

<script>
function approve(){
  alert("Application Approved");
}
</script>
</head>

<body>

<header>Admin Dashboard</header>

<div class="dashboard">
  <div class="card">Total Applications<br>120</div>
  <div class="card">Pending<br>35</div>
  <div class="card">Approved<br>70</div>
  <div class="card">Rejected<br>15</div>
</div>

<table>
<tr>
<th>App ID</th><th>Name</th><th>Service</th><th>Status</th><th>Action</th>
</tr>
<tr>
<td>JSK101</td><td>Rahul</td><td>Aadhaar</td><td>Pending</td>
<td><button onclick="approve()">Approve</button></td>
</tr>
</table>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<canvas id="myChart" width="300" height="200"></canvas>

<script>
const ctx = document.getElementById('myChart');

new Chart(ctx, {
  type: 'bar',
  data: {
    labels: ['Pending','Approved','Rejected'],
    datasets: [{
      label: 'Applications',
      data: [35,70,15],
    }]
  }
});
</script>

</body>
</html>
